# Used by drizzle-kit (via dotenv in drizzle.config.ts) and the Hatchet worker.
# Copy to `.env` and fill in values. Never commit .env.

# Database — same URL as DATABASE_URL in .dev.vars. drizzle-kit reads this
# directly for db:push / db:migrate / db:studio. Also used by Hatchet tasks.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Hatchet — required by the worker process (src/worker.ts).
# On Hatchet Cloud the host:port is inferred from the token.
HATCHET_CLIENT_TOKEN=""
# HATCHET_CLIENT_HOST_PORT="localhost:7077"
