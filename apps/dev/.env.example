# Used by drizzle-kit (via dotenv in drizzle.config.ts) and the local workflows runtime.
# Copy to `.env` and fill in values. Never commit .env.

# Database — same URL as DATABASE_URL in .dev.vars. drizzle-kit reads this
# directly for db:push / db:migrate / db:studio. Also used by workflow runs.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
