{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["./env.d.ts", "@cloudflare/workers-types", "node", "vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@voyantjs/external-refs-react": ["../../packages/external-refs-react/src/index.ts"],
      "@voyantjs/extras-react": ["../../packages/extras-react/src/index.ts"],
      "@voyantjs/facilities-react": ["../../packages/facilities-react/src/index.ts"],
      "@voyantjs/ground-react": ["../../packages/ground-react/src/index.ts"],
      "@voyantjs/identity-react": ["../../packages/identity-react/src/index.ts"],
      "@voyantjs/legal-react": ["../../packages/legal-react/src/index.ts"],
      "@voyantjs/markets-react": ["../../packages/markets-react/src/index.ts"],
      "@voyantjs/sellability-react": ["../../packages/sellability-react/src/index.ts"],
      "@voyantjs/transactions-react": ["../../packages/transactions-react/src/index.ts"],
      "@voyantjs/voyant-ui/*": ["../../packages/ui/src/*"]
    }
  }
}
