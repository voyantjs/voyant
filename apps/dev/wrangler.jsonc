{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voyant-dev",
  "main": "src/entry.ts",
  "compatibility_date": "2025-10-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_URL": "http://localhost:3200/api",
    "DASH_BASE_URL": "http://localhost:3200",
    "KMS_PROVIDER": "local",
    "EMAIL_FROM": "Voyant <voyant@notifications.pixelmakers.com>"
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "dev-placeholder",
      "localConnectionString": "postgresql://voyant:voyant@localhost:5432/voyant_dev"
    }
  ]
}
