{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-booking-requirements-contact-tab",
  "title": "Booking Requirements Contact Tab",
  "description": "Contact requirement table and actions for booking-requirements management screens.",
  "dependencies": [
    "lucide-react",
    "@voyantjs/booking-requirements-react"
  ],
  "registryDependencies": [
    "badge",
    "button"
  ],
  "files": [
    {
      "path": "registry/booking-requirements/booking-requirements-contact-tab.tsx",
      "content": "import type { ContactRequirement } from \"@voyantjs/booking-requirements-react\"\nimport { Pencil, Plus, Trash2 } from \"lucide-react\"\nimport { Badge, Button } from \"@/components/ui\"\n\nexport function BookingRequirementsContactTab({\n  rows,\n  onCreate,\n  onEdit,\n  onDelete,\n}: {\n  rows: ContactRequirement[]\n  onCreate: () => void\n  onEdit: (row: ContactRequirement) => void\n  onDelete: (row: ContactRequirement) => void\n}) {\n  return (\n    <div className=\"flex flex-col gap-4\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h2 className=\"text-lg font-semibold\">Contact Requirements</h2>\n          <p className=\"text-sm text-muted-foreground\">\n            Standard traveler fields collected at booking (name, email, passport, etc.).\n          </p>\n        </div>\n        <Button size=\"sm\" onClick={onCreate}>\n          <Plus className=\"mr-2 h-4 w-4\" />\n          Add Requirement\n        </Button>\n      </div>\n\n      {rows.length === 0 ? (\n        <div className=\"rounded-md border border-dashed p-8 text-center\">\n          <p className=\"text-sm text-muted-foreground\">\n            No contact requirements yet. Add one to start collecting traveler data.\n          </p>\n        </div>\n      ) : (\n        <div className=\"rounded-md border bg-background\">\n          <table className=\"w-full text-sm\">\n            <thead>\n              <tr className=\"border-b text-muted-foreground\">\n                <th className=\"p-3 text-left font-medium\">Field</th>\n                <th className=\"p-3 text-left font-medium\">Scope</th>\n                <th className=\"p-3 text-left font-medium\">Required</th>\n                <th className=\"p-3 text-left font-medium\">Per Participant</th>\n                <th className=\"p-3 text-left font-medium\">Sort</th>\n                <th className=\"p-3 text-left font-medium\">Status</th>\n                <th className=\"w-20 p-3\" />\n              </tr>\n            </thead>\n            <tbody>\n              {rows.map((row) => (\n                <tr key={row.id} className=\"border-b last:border-b-0\">\n                  <td className=\"p-3 font-medium capitalize\">{row.fieldKey.replace(/_/g, \" \")}</td>\n                  <td className=\"p-3 capitalize text-muted-foreground\">\n                    {row.scope.replace(\"_\", \" \")}\n                  </td>\n                  <td className=\"p-3\">\n                    {row.isRequired ? (\n                      <Badge variant=\"default\">Required</Badge>\n                    ) : (\n                      <Badge variant=\"outline\">Optional</Badge>\n                    )}\n                  </td>\n                  <td className=\"p-3\">\n                    {row.perParticipant ? (\n                      <Badge variant=\"secondary\">Yes</Badge>\n                    ) : (\n                      <span className=\"text-xs text-muted-foreground\">No</span>\n                    )}\n                  </td>\n                  <td className=\"p-3 font-mono text-xs\">{row.sortOrder}</td>\n                  <td className=\"p-3\">\n                    <Badge variant={row.active ? \"default\" : \"outline\"}>\n                      {row.active ? \"Active\" : \"Inactive\"}\n                    </Badge>\n                  </td>\n                  <td className=\"p-3\">\n                    <div className=\"flex items-center gap-1\">\n                      <button\n                        type=\"button\"\n                        onClick={() => onEdit(row)}\n                        className=\"text-muted-foreground hover:text-foreground\"\n                      >\n                        <Pencil className=\"h-3.5 w-3.5\" />\n                      </button>\n                      <button\n                        type=\"button\"\n                        onClick={() => onDelete(row)}\n                        className=\"text-muted-foreground hover:text-destructive\"\n                      >\n                        <Trash2 className=\"h-3.5 w-3.5\" />\n                      </button>\n                    </div>\n                  </td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      )}\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/voyant/booking-requirements/booking-requirements-contact-tab.tsx"
    }
  ],
  "type": "registry:component"
}