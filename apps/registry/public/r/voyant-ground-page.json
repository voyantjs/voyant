{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-ground-page",
  "title": "Ground Page",
  "description": "Ground operations shell with operators, vehicles and drivers tabs.",
  "dependencies": ["lucide-react", "@voyantjs/ground-react"],
  "registryDependencies": [
    "tabs",
    "voyant-ground-operators-tab",
    "voyant-ground-vehicles-tab",
    "voyant-ground-drivers-tab"
  ],
  "files": [
    {
      "path": "registry/ground/ground-page.tsx",
      "content": "\"use client\"\n\nimport { Bus } from \"lucide-react\"\n\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\"\nimport { DriversTab } from \"./drivers-tab\"\nimport { OperatorsTab } from \"./operators-tab\"\nimport { VehiclesTab } from \"./vehicles-tab\"\n\nexport function GroundPage() {\n  return (\n    <div className=\"flex flex-col gap-6 p-6\">\n      <div className=\"flex items-center gap-3\">\n        <Bus className=\"h-5 w-5 text-muted-foreground\" />\n        <h1 className=\"text-2xl font-bold tracking-tight\">Ground Operations</h1>\n      </div>\n\n      <Tabs defaultValue=\"operators\" className=\"w-full\">\n        <TabsList>\n          <TabsTrigger value=\"operators\">Operators</TabsTrigger>\n          <TabsTrigger value=\"vehicles\">Vehicles</TabsTrigger>\n          <TabsTrigger value=\"drivers\">Drivers</TabsTrigger>\n        </TabsList>\n        <TabsContent value=\"operators\" className=\"mt-4\">\n          <OperatorsTab />\n        </TabsContent>\n        <TabsContent value=\"vehicles\" className=\"mt-4\">\n          <VehiclesTab />\n        </TabsContent>\n        <TabsContent value=\"drivers\" className=\"mt-4\">\n          <DriversTab />\n        </TabsContent>\n      </Tabs>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/voyant/ground/ground-page.tsx"
    }
  ],
  "type": "registry:component"
}
