{
  "name": "@voyantjs/workflows-local-dashboard",
  "version": "0.0.0",
  "description": "Local dev dashboard served by `voyant workflows serve` / `voyant dev`. Embeds @voyantjs/workflows-ui against the local run store API.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build:bundle": "vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite build --watch",
    "dev:preview": "vite dev"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@uiw/react-codemirror": "^4.23.6",
    "@voyantjs/voyant-ui": "workspace:*",
    "@voyantjs/workflows": "workspace:*",
    "@voyantjs/workflows-react": "workspace:*",
    "lucide-react": "^0.475.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^20.19.8",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vite": "^6.0.0"
  }
}
