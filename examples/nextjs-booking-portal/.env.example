# Point this at a running Voyant API (e.g. templates/dmc at http://localhost:8787/api)
VOYANT_API_URL=http://localhost:8787/api

# Optional API key for the customer actor. Leave blank to rely on session cookies.
VOYANT_API_KEY=

# Browser-facing base URL for authenticated customer account calls.
# In local development this is usually the same as VOYANT_API_URL, but in a
# production deployment you would typically point this at the public site or
# reverse-proxied Voyant origin that owns the customer session cookie.
NEXT_PUBLIC_VOYANT_CUSTOMER_API_URL=http://localhost:8787/api

# Set to "1" to skip the network and render mock data instead. Useful for
# demoing the booking portal without a live Voyant backend.
USE_MOCK_DATA=1
