{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-crm-quotes-page",
  "title": "Quotes Page",
  "description": "Quotes list page shell with status filtering and create action.",
  "dependencies": ["lucide-react", "@voyantjs/crm-react", "@voyantjs/utils"],
  "registryDependencies": ["badge", "button", "select", "table", "voyant-crm-create-quote-dialog"],
  "files": [
    {
      "path": "registry/crm/quotes-page.tsx",
      "content": "import { useNavigate } from \"@tanstack/react-router\"\nimport { type QuoteRecord, useQuotes } from \"@voyantjs/crm-react\"\nimport { Loader2, Plus } from \"lucide-react\"\nimport { useState } from \"react\"\nimport {\n  Badge,\n  Button,\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui\"\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from \"@/components/ui/table\"\nimport {\n  formatDate,\n  formatMoney,\n  formatRelative,\n  QUOTE_STATUS_OPTIONS,\n} from \"@/components/voyant/crm/crm-constants\"\nimport { CreateQuoteDialog } from \"./create-quote-dialog\"\n\nexport function QuotesPage() {\n  const navigate = useNavigate()\n  const [statusFilter, setStatusFilter] = useState<string>(\"all\")\n  const [dialogOpen, setDialogOpen] = useState(false)\n\n  const { data, isPending, isError } = useQuotes({\n    status: statusFilter === \"all\" ? undefined : statusFilter,\n    limit: 100,\n  })\n\n  const quotes = data?.data ?? []\n\n  return (\n    <div className=\"flex flex-col gap-6 p-6\">\n      <div className=\"flex items-start justify-between gap-3\">\n        <div>\n          <h1 className=\"text-2xl font-bold tracking-tight\">Quotes</h1>\n          <p className=\"text-sm text-muted-foreground\">\n            Quotes issued for opportunities in your pipeline.\n          </p>\n        </div>\n        <Button onClick={() => setDialogOpen(true)}>\n          <Plus className=\"mr-2 size-4\" />\n          New quote\n        </Button>\n      </div>\n\n      <div className=\"flex flex-wrap items-center gap-3\">\n        <Select value={statusFilter} onValueChange={(v) => setStatusFilter(v ?? \"all\")}>\n          <SelectTrigger className=\"w-[180px] text-sm\">\n            <SelectValue placeholder=\"Status\" />\n          </SelectTrigger>\n          <SelectContent>\n            <SelectItem value=\"all\">All statuses</SelectItem>\n            {QUOTE_STATUS_OPTIONS.map((o) => (\n              <SelectItem key={o.value} value={o.value}>\n                {o.label}\n              </SelectItem>\n            ))}\n          </SelectContent>\n        </Select>\n      </div>\n\n      <div className=\"rounded-md border\">\n        <Table>\n          <TableHeader>\n            <TableRow>\n              <TableHead>Quote</TableHead>\n              <TableHead>Status</TableHead>\n              <TableHead>Total</TableHead>\n              <TableHead>Valid until</TableHead>\n              <TableHead>Updated</TableHead>\n            </TableRow>\n          </TableHeader>\n          <TableBody>\n            {isPending ? (\n              <TableRow>\n                <TableCell colSpan={5} className=\"h-24 text-center\">\n                  <Loader2 className=\"mx-auto size-4 animate-spin text-muted-foreground\" />\n                </TableCell>\n              </TableRow>\n            ) : isError ? (\n              <TableRow>\n                <TableCell colSpan={5} className=\"h-24 text-center text-sm text-destructive\">\n                  Failed to load quotes.\n                </TableCell>\n              </TableRow>\n            ) : quotes.length === 0 ? (\n              <TableRow>\n                <TableCell colSpan={5} className=\"h-24 text-center text-sm text-muted-foreground\">\n                  No quotes found.\n                </TableCell>\n              </TableRow>\n            ) : (\n              quotes.map((q: QuoteRecord) => (\n                <TableRow\n                  key={q.id}\n                  onClick={() => void navigate({ to: \"/quotes/$id\", params: { id: q.id } })}\n                  className=\"cursor-pointer\"\n                >\n                  <TableCell className=\"font-mono text-xs\">{q.id.slice(-8)}</TableCell>\n                  <TableCell>\n                    <Badge variant=\"secondary\" className=\"capitalize\">\n                      {q.status}\n                    </Badge>\n                  </TableCell>\n                  <TableCell className=\"font-medium\">\n                    {formatMoney(q.totalAmountCents, q.currency)}\n                  </TableCell>\n                  <TableCell>{formatDate(q.validUntil)}</TableCell>\n                  <TableCell className=\"text-muted-foreground\">\n                    {formatRelative(q.updatedAt)}\n                  </TableCell>\n                </TableRow>\n              ))\n            )}\n          </TableBody>\n        </Table>\n      </div>\n\n      <CreateQuoteDialog open={dialogOpen} onOpenChange={setDialogOpen} />\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/voyant/crm/quotes-page.tsx"
    }
  ],
  "type": "registry:component"
}
