{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-supplier-service-row",
  "title": "Supplier Service Row",
  "description": "Expandable supplier service row with nested rates table and row actions.",
  "dependencies": [
    "lucide-react",
    "@voyantjs/suppliers-react"
  ],
  "registryDependencies": [
    "badge",
    "button"
  ],
  "files": [
    {
      "path": "registry/suppliers/supplier-service-row.tsx",
      "content": "import {\n  formatAmount,\n  formatUnit,\n  type SupplierRate,\n  type SupplierService,\n} from \"@voyantjs/suppliers-react\"\nimport { ChevronDown, ChevronRight, Pencil, Plus, Trash2 } from \"lucide-react\"\nimport { Badge, Button } from \"@/components/ui\"\n\nexport function SupplierServiceRow({\n  service,\n  rates,\n  expanded,\n  onToggle,\n  onEdit,\n  onDelete,\n  onAddRate,\n  onEditRate,\n  onDeleteRate,\n}: {\n  service: SupplierService\n  rates: SupplierRate[]\n  expanded: boolean\n  onToggle: () => void\n  onEdit: () => void\n  onDelete: () => void\n  onAddRate: () => void\n  onEditRate: (rate: SupplierRate) => void\n  onDeleteRate: (rateId: string) => void\n}) {\n  return (\n    <div className=\"rounded-md border\">\n      <div className=\"flex items-center gap-3 p-3\">\n        <button\n          type=\"button\"\n          onClick={onToggle}\n          className=\"text-muted-foreground hover:text-foreground\"\n        >\n          {expanded ? <ChevronDown className=\"h-4 w-4\" /> : <ChevronRight className=\"h-4 w-4\" />}\n        </button>\n        <div className=\"flex-1\">\n          <span className=\"text-sm font-medium\">{service.name}</span>\n          <div className=\"mt-0.5 flex items-center gap-2\">\n            <Badge variant=\"outline\" className=\"text-xs capitalize\">\n              {service.serviceType}\n            </Badge>\n            {service.duration ? (\n              <span className=\"text-xs text-muted-foreground\">{service.duration}</span>\n            ) : null}\n            {service.capacity ? (\n              <span className=\"text-xs text-muted-foreground\">max {service.capacity} pax</span>\n            ) : null}\n            {!service.active ? (\n              <Badge variant=\"secondary\" className=\"text-xs\">\n                Inactive\n              </Badge>\n            ) : null}\n          </div>\n        </div>\n        <div className=\"flex items-center gap-1\">\n          <Button variant=\"ghost\" size=\"sm\" onClick={onEdit}>\n            <Pencil className=\"h-3.5 w-3.5\" />\n          </Button>\n          <Button variant=\"ghost\" size=\"sm\" onClick={onDelete}>\n            <Trash2 className=\"h-3.5 w-3.5\" />\n          </Button>\n        </div>\n      </div>\n\n      {expanded ? (\n        <div className=\"border-t bg-muted/30 p-3\">\n          <div className=\"mb-2 flex items-center justify-between\">\n            <p className=\"text-xs font-medium uppercase tracking-wide text-muted-foreground\">\n              Rates\n            </p>\n            <Button variant=\"outline\" size=\"sm\" onClick={onAddRate}>\n              <Plus className=\"mr-1 h-3 w-3\" />\n              Add Rate\n            </Button>\n          </div>\n\n          {rates.length === 0 ? (\n            <p className=\"py-2 text-center text-xs text-muted-foreground\">No rates yet.</p>\n          ) : (\n            <div className=\"rounded border bg-background\">\n              <table className=\"w-full text-xs\">\n                <thead>\n                  <tr className=\"border-b text-muted-foreground\">\n                    <th className=\"p-2 text-left font-medium\">Name</th>\n                    <th className=\"p-2 text-left font-medium\">Amount</th>\n                    <th className=\"p-2 text-left font-medium\">Unit</th>\n                    <th className=\"p-2 text-left font-medium\">Valid</th>\n                    <th className=\"p-2 text-left font-medium\">Pax</th>\n                    <th className=\"w-16 p-2\" />\n                  </tr>\n                </thead>\n                <tbody>\n                  {rates.map((rate) => (\n                    <tr key={rate.id} className=\"border-b last:border-b-0\">\n                      <td className=\"p-2\">{rate.name}</td>\n                      <td className=\"p-2 font-mono\">\n                        {formatAmount(rate.amountCents, rate.currency)}\n                      </td>\n                      <td className=\"p-2 capitalize\">{formatUnit(rate.unit)}</td>\n                      <td className=\"p-2\">\n                        {rate.validFrom || rate.validTo\n                          ? `${rate.validFrom ?? \"...\"} — ${rate.validTo ?? \"...\"}`\n                          : \"-\"}\n                      </td>\n                      <td className=\"p-2\">\n                        {rate.minPax || rate.maxPax\n                          ? `${rate.minPax ?? \"?\"}-${rate.maxPax ?? \"?\"}`\n                          : \"-\"}\n                      </td>\n                      <td className=\"p-2\">\n                        <div className=\"flex items-center gap-1\">\n                          <button\n                            type=\"button\"\n                            onClick={() => onEditRate(rate)}\n                            className=\"text-muted-foreground hover:text-foreground\"\n                          >\n                            <Pencil className=\"h-3 w-3\" />\n                          </button>\n                          <button\n                            type=\"button\"\n                            onClick={() => onDeleteRate(rate.id)}\n                            className=\"text-muted-foreground hover:text-destructive\"\n                          >\n                            <Trash2 className=\"h-3 w-3\" />\n                          </button>\n                        </div>\n                      </td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </div>\n      ) : null}\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/voyant/suppliers/supplier-service-row.tsx"
    }
  ],
  "type": "registry:component"
}