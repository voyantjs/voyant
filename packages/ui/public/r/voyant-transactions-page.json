{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-transactions-page",
  "title": "Transactions Page",
  "description": "Transactions management page shell with offers and orders tabs.",
  "dependencies": ["@voyantjs/transactions-react", "lucide-react"],
  "registryDependencies": [
    "tabs",
    "voyant-transactions-offers-tab",
    "voyant-transactions-orders-tab"
  ],
  "files": [
    {
      "path": "registry/transactions/transactions-page.tsx",
      "content": "\"use client\"\n\nimport { Receipt } from \"lucide-react\"\n\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\"\nimport { OffersTab } from \"./offers-tab\"\nimport { OrdersTab } from \"./orders-tab\"\n\nexport function TransactionsPage() {\n  return (\n    <div className=\"flex flex-col gap-6 p-6\">\n      <div className=\"flex items-center gap-3\">\n        <Receipt className=\"h-5 w-5 text-muted-foreground\" />\n        <h1 className=\"text-2xl font-bold tracking-tight\">Transactions</h1>\n      </div>\n\n      <p className=\"max-w-2xl text-sm text-muted-foreground\">\n        Commercial documents. Offers represent priced proposals, orders represent committed\n        purchases.\n      </p>\n\n      <Tabs defaultValue=\"offers\" className=\"w-full\">\n        <TabsList>\n          <TabsTrigger value=\"offers\">Offers</TabsTrigger>\n          <TabsTrigger value=\"orders\">Orders</TabsTrigger>\n        </TabsList>\n        <TabsContent value=\"offers\" className=\"mt-4\">\n          <OffersTab />\n        </TabsContent>\n        <TabsContent value=\"orders\" className=\"mt-4\">\n          <OrdersTab />\n        </TabsContent>\n      </Tabs>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/voyant/transactions/transactions-page.tsx"
    }
  ],
  "type": "registry:component"
}
