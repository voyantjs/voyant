{
  "name": "@voyantjs/vault",
  "version": "0.13.0",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./service": "./src/service.ts",
    "./providers/env": "./src/providers/env.ts",
    "./providers/voyant-cloud": "./src/providers/voyant-cloud.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/voyant-cloud": "workspace:*"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js"
      },
      "./providers/env": {
        "types": "./dist/providers/env.d.ts",
        "import": "./dist/providers/env.js"
      },
      "./providers/voyant-cloud": {
        "types": "./dist/providers/voyant-cloud.d.ts",
        "import": "./dist/providers/voyant-cloud.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/vault"
  }
}
