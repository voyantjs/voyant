{
  "name": "@voyantjs/workflows-config",
  "version": "0.6.9",
  "description": "Types and `defineConfig` helper for `voyant.config.ts`.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/workflows-config"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
