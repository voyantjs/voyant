{
  "name": "@voyantjs/workflows-orchestrator-node",
  "version": "0.6.8",
  "description": "Node/Docker runtime primitives for @voyantjs/workflows-orchestrator, including a file-backed run store and local scheduler.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/workflows-orchestrator-node"
  },
  "homepage": "https://voyant.cloud/workflows",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "drizzle",
    "src",
    "!**/*.test.*",
    "!**/*.spec.*",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "dev": "tsc -w -p tsconfig.json",
    "test:integration": "vitest run --maxWorkers=1 --testTimeout=30000 --hookTimeout=30000 src/__tests__/migrate.integration.test.ts src/__tests__/postgres-integration.test.ts src/__tests__/selfhost-server-postgres.integration.test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@voyantjs/workflows-orchestrator": "workspace:*",
    "@voyantjs/workflows": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.20.0",
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
