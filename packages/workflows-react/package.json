{
  "name": "@voyantjs/workflows-react",
  "version": "0.6.8",
  "description": "React hooks for Voyant Workflows \u2014 trigger, subscribe, and stream runs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/workflows-react"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!**/*.test.*",
    "!**/*.spec.*",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "dev": "tsc -w -p tsconfig.json"
  },
  "dependencies": {
    "@voyantjs/workflows-errors": "workspace:*",
    "@voyantjs/workflows": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "react": "^19.1.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
